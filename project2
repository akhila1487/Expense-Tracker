import tkinter as tk
from tkinter import messagebox

# List to store expenses
expenses = []

def add_expense():
    try:
        amount = float(expense_entry.get())
        expenses.append(amount)

        expense_list.insert(tk.END, f"₹{amount:.2f}")

        total = sum(expenses)
        total_label.config(text=f"Total Spent: ₹{total:.2f}")

        expense_entry.delete(0, tk.END)

    except ValueError:
        messagebox.showerror("Invalid Input", "Please enter a valid amount.")

# Main Window
root = tk.Tk()
root.title("Expense Tracker")
root.geometry("400x450")
root.resizable(False, False)

# Heading
heading = tk.Label(root, text="Expense Tracker", font=("Arial", 18, "bold"))
heading.pack(pady=10)

# Expense Entry
expense_entry = tk.Entry(root, font=("Arial", 14))
expense_entry.pack(pady=10)

# Add Button
add_btn = tk.Button(root, text="Add Expense", font=("Arial", 12),
                    command=add_expense)
add_btn.pack(pady=5)

# Expense List
expense_list = tk.Listbox(root, width=30, height=10, font=("Arial", 12))
expense_list.pack(pady=10)

# Total Label
total_label = tk.Label(root, text="Total Spent: ₹0.00",
                       font=("Arial", 14, "bold"))
total_label.pack(pady=10)

root.mainloop()